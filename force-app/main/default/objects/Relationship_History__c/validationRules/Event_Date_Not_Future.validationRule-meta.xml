<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Event_Date_Not_Future</fullName>
    <active>true</active>
    <description>The event date cannot be in the future.</description>
    <errorConditionFormula>Event_Date__c &gt; NOW()</errorConditionFormula>
    <errorDisplayField>Event_Date__c</errorDisplayField>
    <errorMessage>Event Date cannot be in the future.</errorMessage>
</ValidationRule>
